{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "PDFMathTranslate Desktop",
  "version": "0.1.0",
  "identifier": "com.pdfmathtranslate.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PDFMathTranslate Desktop",
        "width": 1600,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
